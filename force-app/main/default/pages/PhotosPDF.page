<apex:page controller="PhotosPDFController" renderAs="pdf" showHeader="false" sidebar="false">
<head>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    .photo-page {
        width: 100%;
        height: 100vh;
        text-align: center;
        page-break-after: always;
    }
    .photo-page:last-child {
        page-break-after: avoid;
    }
    img {
        max-width: 100%;
        max-height: 100vh;
        object-fit: contain;
    }
</style>
</head>
<body>
    <apex:repeat value="{!photos}" var="photo">
        <div class="photo-page">
            <apex:image url="{!photo.imageUrl}" />
        </div>
    </apex:repeat>
</body>
</apex:page>
